body {
    background: pink;
    text-align: center;
    font-family: Arial;
}

.container {
    margin-top: 120px;
}

h1 {
    color: red;
    font-size: 40px;
}

.heart {
    width: 200px;
    animation: beat 1s infinite;
}

@keyframes beat {
    0% { transform: scale(1); }
    50% { transform: scale(1.25); }
    100% { transform: scale(1); }
}